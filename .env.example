DEFAULT_API_URL=
# Prefer an env ref such as ${OPENAI_API_KEY}; literal keys are stored as plaintext in SQLite.
DEFAULT_API_KEY=
DEFAULT_API_PATH=/v1/images/generations
DEFAULT_RESPONSES_MODEL=gpt-5.4
APP_VERSION=
GITHUB_REPO=Z1rconium/gpt-image-linux
# Latest-version check. The backend reads GitHub latest release first, then falls back to this branch's VERSION file.
ENABLE_VERSION_CHECK=true
VERSION_CHECK_TIMEOUT_SECONDS=3
VERSION_CHECK_BRANCH=main
# Optional JSON counters/gauges/rates and Prometheus metrics at /api/metrics.
ENABLE_METRICS=false
# Log /api/gallery requests at or above this threshold with filters/page/total and DB query time.
SLOW_GALLERY_QUERY_MS=200

# Prompt Optimizer. Uses a server-side Chat Completions-compatible endpoint.
PROMPT_OPTIMIZER_ENABLED=false
PROMPT_OPTIMIZER_API_URL=
# Prefer an env ref such as ${OPENAI_API_KEY}; literal keys are stored as plaintext in SQLite.
PROMPT_OPTIMIZER_API_KEY=
PROMPT_OPTIMIZER_MODEL=gpt-4o-mini
PROMPT_OPTIMIZER_TIMEOUT_SECONDS=20
PROMPT_OPTIMIZER_MAX_OUTPUT_CHARS=4000
PROMPT_OPTIMIZER_HOST_ALLOWLIST=

ACCESS_KEY=
ALLOW_UNAUTHENTICATED=false
IP_ALLOWLIST=
TRUST_PROXY_HEADERS=false
MAX_FILE_SIZE_MB=50
# Maximum upstream JSON/SSE response body size in MB. Prefer response_format=url for large images.
MAX_UPSTREAM_JSON_MB=128

# Import archive limits
# Maximum uploaded ZIP size in MB. Recommended: keep this comfortably above MAX_FILE_SIZE_MB.
IMPORT_ARCHIVE_MAX_MB=1000
# Maximum number of files allowed inside one import archive.
IMPORT_MAX_FILES=500
# Maximum total uncompressed archive size in MB after extraction.
IMPORT_MAX_UNCOMPRESSED_MB=1024
# Maximum metadata.json size in bytes.
IMPORT_MAX_METADATA_BYTES=2097152
# Maximum allowed uncompressed/compressed ratio to reduce zip bomb risk.
IMPORT_MAX_COMPRESSION_RATIO=100

# Background job limits
# Maximum number of generation/edit jobs running at the same time.
MAX_ACTIVE_GENERATE_JOBS=2
# Maximum number of additional queued generation/edit jobs.
MAX_QUEUED_GENERATE_JOBS=20
# Maximum total pending edit source image bytes, in MB. Set 0 to disable this byte cap.
MAX_PENDING_EDIT_SOURCE_MB=200

PYTHON_BASE_IMAGE=python:3.11-slim

# Security settings
ACCESS_COOKIE_SECURE=true
ACCESS_MAX_FAILURES=5
ACCESS_LOCKOUT_SECONDS=300
UPSTREAM_HOST_ALLOWLIST=
WEBHOOK_HOST_ALLOWLIST=
WEBHOOK_SIGNING_SECRET=
WEBHOOK_TIMEOUT_SECONDS=5
WEBHOOK_MAX_ATTEMPTS=3
