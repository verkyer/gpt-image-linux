{
  "scripts": {
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "frontend:check": "npm --prefix frontend run check",
    "backend:dev": "uvicorn backend.app.main:app --host 0.0.0.0 --port 9090 --reload",
    "test:contract": "python3 -m pytest backend/tests/test_contract.py -q",
    "test:e2e": "npm --prefix frontend run test:e2e",
    "test:e2e:perf": "npm --prefix frontend run test:e2e:perf",
    "test:perf": "RUN_PERFORMANCE_TESTS=true python3 -m pytest backend/tests/test_performance.py -q"
  }
}
